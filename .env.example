# 可选 API Token
DEEPSEEK_API_KEY=your_deepseek_api_key
DEEPSEEK_API_BASE=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-v4-flash
DEEPSEEK_TIMEOUT_SECONDS=60
PRODUCT_HUNT_TOKEN=
GITHUB_TOKEN=
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=

# 运行配置
MAX_ITEMS_PER_SOURCE=8
TARGET_QUERY=artificial intelligence OR AI OR machine learning
OUTPUT_DIR=outputs

# LLM stage 配置
# USE_LLM 控制是否实际调用 LLM；REQUIRE_LLM 控制没有可用 LLM 或 LLM 失败时是否直接失败。
STRUCTURE_EVENTS_USE_LLM=1
STRUCTURE_EVENTS_REQUIRE_LLM=1
STRUCTURE_EVENTS_MAX_ITEMS_PER_SCOPE=20
ANALYZE_INSIGHTS_USE_LLM=1
ANALYZE_INSIGHTS_REQUIRE_LLM=1
ANALYZE_REACT_MAX_STEPS=5
# Stage 5 标题翻译会使用 DeepSeek；如果没有 key，generate_report linter 会失败。
TRANSLATE_TITLES_REQUIRE_LLM=1
